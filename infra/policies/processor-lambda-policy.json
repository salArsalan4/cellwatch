{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WriteRawArchive",
      "Effect": "Allow",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::cellwatch-raw-ACCOUNT_ID/raw/*"
    },
    {
      "Sid": "ReadWriteKpiTable",
      "Effect": "Allow",
      "Action": ["dynamodb:PutItem", "dynamodb:GetItem"],
      "Resource": "arn:aws:dynamodb:REGION:ACCOUNT_ID:table/cellwatch-kpi"
    },
    {
      "Sid": "PublishAnomalyAlerts",
      "Effect": "Allow",
      "Action": "sns:Publish",
      "Resource": "arn:aws:sns:REGION:ACCOUNT_ID:cellwatch-alerts"
    },
    {
      "Sid": "WriteOwnLogs",
      "Effect": "Allow",
      "Action": ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"],
      "Resource": "arn:aws:logs:REGION:ACCOUNT_ID:log-group:/aws/lambda/cellwatch-processor:*"
    }
  ]
}
